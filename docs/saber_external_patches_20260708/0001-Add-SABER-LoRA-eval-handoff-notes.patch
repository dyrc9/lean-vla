+#!/usr/bin/env python3
+from pathlib import Path
+import argparse
+import torch
+from transformers import AutoModelForCausalLM, AutoTokenizer
+from peft import PeftModel
+
+OBJECTIVE_TO_LORA = {
+    "task_failure": "IntelligenceLab/saber-attack-agent-task-failure",
+    "action_inflation": "IntelligenceLab/saber-attack-agent-action-inflation",
+    "constraint_violation": "IntelligenceLab/saber-attack-agent-constraint-violation",
+}
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--objective", required=True, choices=OBJECTIVE_TO_LORA.keys())
+    parser.add_argument("--base", default="Qwen/Qwen2.5-3B-Instruct")
+    parser.add_argument("--out-dir", default="outputs/hf_merged_attack_agents")
+    args = parser.parse_args()
+
+    lora_id = OBJECTIVE_TO_LORA[args.objective]
+    out = Path(args.out_dir) / args.objective
+    out.mkdir(parents=True, exist_ok=True)
+
+    tokenizer = AutoTokenizer.from_pretrained(args.base, trust_remote_code=True)
+    base = AutoModelForCausalLM.from_pretrained(
+        args.base,
+        torch_dtype=torch.bfloat16,
+        device_map="auto",
+        trust_remote_code=True,
+    )
+    model = PeftModel.from_pretrained(base, lora_id)
+    merged = model.merge_and_unload()
+
+    merged.save_pretrained(out, safe_serialization=True)
+    tokenizer.save_pretrained(out)
+    print(f"Saved merged SABER {args.objective} model to {out}")
+
+if __name__ == "__main__":
+    main()
